# Logs
**/logs
**/*.log
**/npm-debug.log*
**/yarn-debug.log*
**/yarn-error.log*

# Runtime data
**/pids
**/*.pid
**/*.seed
**/*.pid.lock

# Directory for instrumented libs generated by jscoverage/Jest
**/lib-cov

# Coverage directory used by tools like istanbul
**/coverage
**/.nyc_output

# Dependency directories
**/node_modules/

# Optional npm cache directory
**/.npm

# Optional eslint cache
**/.eslintcache

# dotenv environment files
**/.env
**/.env.*.local

# TypeScript
**/*.tsbuildinfo

# IDEs and editors
**/.idea/
**/.vscode/
**/*.suo
**/*.ntvs*
**/*.njsproj
**/*.sln

# macOS
.DS_Store

# Angular build artifacts
/frontend/dist/
/frontend/.angular/cache/
/frontend/.angular/

# Angular environment files (optional)
